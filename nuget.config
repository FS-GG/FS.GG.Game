<?xml version="1.0" encoding="utf-8"?>
<!-- nuget.config (repo root) — HERMETIC restore for FS.GG.Game (ADR-0022 / P2).

     FS.GG.Game.Core is BCL-only: every dependency (FSharp.Core plus the Expecto / FsCheck /
     Microsoft.NET.Test.Sdk / YoloDev test stack) is a PUBLIC nuget.org package. It consumes NO
     FS.GG.* org-feed package yet, so — unlike the sibling repos — this config does NOT add the
     private org GitHub Packages feed. (When FS.GG.Game.Render lands in P4 it will consume
     FS.GG.UI.Scene from the org feed: add the `fsgg-github` source, packageSourceMapping, and the
     `packages: read` CI credential then, mirroring FS.GG.Rendering's nuget.config.)

     WHY the two clears: the committed packages.lock.json must restore byte-reproducibly under CI's
     locked-restore gate (lockfile-restore-enforcement, ADR-0006). Two environment-specific sources
     otherwise poison the recorded content hash:
       1. inherited machine sources (e.g. a dev local-feed): dropped by packageSources clear.
       2. the .NET SDK's implicit FSharp.Core OFFLINE fallback (sdk/<v>/FSharp/library-packs/), whose
          content hash differs from the nuget.org package. A CI runner that resolves FSharp.Core from
          that fallback records a different hash than a local restore from nuget.org, tripping NU1403.
          Clearing fallbackPackageFolders forces FSharp.Core to resolve from nuget.org in every
          environment, so the lockfile hash is reproducible local == CI. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
