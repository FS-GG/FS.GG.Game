#!/usr/bin/env bash
# The committed NuGet lockfiles (packages.lock.json) as the `scripts/generated-paths` roster contract
# (ADR-0044, .github#498): one `kind<TAB>path<TAB>marker` row per file, EMPTY marker = a whole file
# nobody authors.
#
# These are GENERATED by `dotnet restore --force-evaluate`, one per project: the reusable lockfile-sync
# workflow (.github/workflows/lockfile-sync.yml) regenerates them on renovate/* PRs, and gate.yml's
# locked-restore (ADR-0006) holds every restore to them. So `intra-repo-parallel-work` §1 applies — a
# worker who adds a package reference regenerates the lock next to it, and was told NOT to reserve it in
# their touch-set, so drift on it is a rebase, not a decision (#309/#498).
#
# There is no single "lock generator" script here to ask (the generator is `dotnet restore`), so the
# honest source of WHICH locks exist is the tree itself, read via `git ls-files` — a DERIVATION, never a
# hand-kept list: a new project's lock appears here the moment it is committed, which is exactly when it
# becomes a drift candidate, and a removed project's lock disappears with it. That failure direction is
# the safe one: a lock this misses is simply not subtracted, so a worker sees the drift line they see
# today (fail-closed noise), never a suppressed real finding.
#
#   scripts/list-lockfiles --list   # the roster contract (the form `generated-paths` invokes)
set -euo pipefail

case "${1:-}" in
  --list | "") ;;
  *) echo "::error::list-lockfiles: unknown argument: $1 (expected --list or nothing)" >&2; exit 2 ;;
esac

HERE="$(cd "$(dirname "$0")/.." && pwd)"
cd "$HERE"

# `git ls-files` fails CLOSED: outside a work tree, or with git absent, it errors non-zero and
# `generated-paths`' own `ask()` turns that into "these artifacts are NOT subtracted" on stderr — never
# a silent empty that would read as "this repo has no lockfiles".
git ls-files -- '*packages.lock.json' | while IFS= read -r p; do
  [ -n "$p" ] && printf 'lockfile\t%s\t\n' "$p"
done
